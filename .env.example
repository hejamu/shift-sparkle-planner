# Database (currently unused — backend writes to /data/shiftplanner.sqlite)
DB_HOST=db
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=shiftplanner

# Backend session signing key — REQUIRED. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-me-with-a-long-random-string

# Initial admin password seeded on first boot if no admin exists.
# Rotate via the admin UI immediately after first login.
ADMIN_DEFAULT_PASSWORD=changeme
